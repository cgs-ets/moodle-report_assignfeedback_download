{{!
    @template report_assignfeedback_download/studentsfilter

    Template for the assignment reports students filter.

    Example context (json):
    {
        "tableregionid": "assignfeedback-students-2",
        "courseid": 2,
        "filtertypes": [
            {
                "name": "status",
                "title": "Submission status",
                "values": [
                    {
                        "value": 1,
                        "title": "Submitted"
                    },
                    {
                        "value": 0,
                        "title": "Not submitted"
                    }
                ]
            }
        ]
    }
}}
<form method="dialog">
    <div id="core-filter-{{uniqid}}"
         class="filter-group my-2 p-2 bg-light border-radius border"
         data-table-region="{{tableregionid}}"
         data-table-course-id="{{courseid}}"
         data-filterverb="2">
        {{> core/datafilter/filter_match }}

        <div data-filterregion="filters">
            {{> core/datafilter/filter_row }}
        </div>

        <div class="d-flex" data-filterregion="actions">
            &nbsp;
            <button type="button" class="btn btn-link text-reset" data-filteraction="add">
                {{#pix}}t/add{{/pix}}<span class="ps-3">{{#str}}addcondition{{/str}}</span>
            </button>
            <button data-filteraction="reset" type="button" class="btn btn-secondary ms-auto me-2">{{#str}}clearfilters{{/str}}</button>
            <button data-filteraction="apply" type="submit" class="btn btn-primary">{{#str}}applyfilters{{/str}}</button>
        </div>

        {{> core/datafilter/filter_types }}
    </div>
</form>

{{#js}}
    require(['report_assignfeedback_download/students_filter'], function(StudentsFilter) {
        StudentsFilter.init('core-filter-{{uniqid}}');
    });
{{/js}}
